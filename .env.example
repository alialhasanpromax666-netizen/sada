# ════════════════════════════════════════════════════════════
#  صَدَى (Sada) — متغيّرات البيئة
#  انسخ هذا الملف إلى .env ثم املأ القيم.
#
#  للنشر على Vercel + Neon (مجاناً):
#    1. أنشئ حساباً على https://neon.tech واحصل على رابط PostgreSQL
#    2. أنشئ مشروعاً على https://vercel.com (import من GitHub)
#    3. أضف كل المتغيّرات أدناه في Vercel Dashboard → Project Settings → Environment Variables
#    4. أضف ANTHROPIC_API_KEY الحقيقي
# ════════════════════════════════════════════════════════════

# ── قاعدة البيانات ───────────────────────────────────────────
# محلياً (SQLite): DATABASE_URL="file:./dev.db" (عدّل prisma/schema.prisma إلى provider = "sqlite")
# إنتاجاً (Neon PostgreSQL): احصل على رابط من https://neon.tech
DATABASE_URL="postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/sada?sslmode=require"

# ── مفتاح التشفير الرئيسي (AES-256) ──────────────────────────
# 32 بايت بصيغة base64. وَلِّده عبر:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# تحذير: تغييره يجعل كل المفاتيح المخزّنة غير قابلة للفك. احفظه بأمان.
SADA_MASTER_KEY="ضع_هنا_مفتاحاً_عشوائياً_بطول_32_بايت_base64"

# ── محرك الذكاء (Claude) ─────────────────────────────────────
# يُستخدم لتوليد محتوى الوكلاء. احصل على مفتاح من console.anthropic.com
ANTHROPIC_API_KEY="sk-ant-..."

# النموذج الافتراضي لتوليد المحتوى
SADA_AQL_MODEL="claude-opus-4-8"

# ── NextAuth (المصادقة) ────────────────────────────────────────
# سلسلة عشوائية لتوقيع JWT. وَلِّدها عبر:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NEXTAUTH_SECRET="ضع_هنا_مفتاحاً_عشوائياً"
NEXTAUTH_URL="http://localhost:3000"

# ── مفتاح النشر التلقائي (cron) ─────────────────────────────
# يُستخدم للمصادقة على نداءات المشغّل الدوري (cron-job.org).
# وَلِّده عبر: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET="ضع_هنا_مفتاحاً_عشوائياً"

# ── عنوان التطبيق (للروابط الداخلية + خطّاف ويب تيليغرام) ─────
# يجب أن يكون عنواناً عامّاً (HTTPS) لتفعيل خطّاف الويب. محلياً
# استخدم نفقاً مثل ngrok وضع رابطه هنا.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── تيليغرام (إدارة القناة عبر بوت) ──────────────────────────
# مفتاح البوت يُخزَّن مشفّراً في خزنة المفاتيح بصيغة: «الرمز|@القناة».
# سرّ اختياري للتحقّق من أنّ نداءات خطّاف الويب آتية من تيليغرام فعلاً.
#   وَلِّده عبر: node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
SADA_TELEGRAM_WEBHOOK_SECRET=""
# معرّف مستخدم تيليغرام المصرّح له وحده ببثّ الإعلانات عبر أوامر البوت (اختياري).
SADA_TELEGRAM_ADMIN_ID=""
